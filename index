<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#fbf5ee" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-title" content="对话札记" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <title>对话札记</title>
  <style>
    :root {
      --bg: #fbf5ee;
      --bg-2: #fffaf5;
      --card: rgba(255, 252, 248, 0.88);
      --card-solid: #fffdfa;
      --text: #2f2924;
      --muted: #8b7a6d;
      --line: rgba(142, 114, 91, 0.18);
      --accent: #9d775f;
      --accent-dark: #765544;
      --accent-soft: #f2e6dc;
      --danger: #b76156;
      --danger-soft: #f6e0dd;
      --shadow: 0 18px 45px rgba(91, 61, 38, 0.12);
      --shadow-soft: 0 8px 24px rgba(91, 61, 38, 0.08);
      --radius-xl: 28px;
      --radius-lg: 22px;
      --radius-md: 16px;
      --footer-hint: 196px;
    }

    * {
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
    }

    html, body {
      margin: 0;
      min-height: 100%;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
      background:
        radial-gradient(circle at 12% 0%, rgba(246, 220, 196, 0.85), transparent 31%),
        radial-gradient(circle at 92% 10%, rgba(248, 233, 218, 0.92), transparent 34%),
        linear-gradient(180deg, var(--bg), var(--bg-2));
      color: var(--text);
      min-height: 100vh;
    }

    button, input, textarea {
      font: inherit;
    }

    button {
      border: 0;
      cursor: pointer;
      user-select: none;
    }

    button:active {
      transform: scale(0.97);
    }

    .app {
      width: min(920px, 100%);
      margin: 0 auto;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      padding: calc(14px + env(safe-area-inset-top)) 14px 0;
    }

    .topbar {
      position: sticky;
      top: 0;
      z-index: 5;
      padding: 0 0 10px;
      background: linear-gradient(180deg, rgba(251, 245, 238, 0.96), rgba(251, 245, 238, 0));
      backdrop-filter: blur(14px);
    }

    .top-card {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-soft);
      padding: 13px;
      backdrop-filter: blur(18px);
    }

    .brand-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 10px;
    }

    .brand {
      display: flex;
      flex-direction: column;
      gap: 2px;
      min-width: 0;
    }

    h1 {
      margin: 0;
      font-size: 18px;
      line-height: 1.2;
      letter-spacing: 0.02em;
    }

    .hint {
      color: var(--muted);
      font-size: 12px;
      line-height: 1.35;
    }

    .top-fields {
      display: grid;
      grid-template-columns: 1fr 1fr auto;
      gap: 8px;
      align-items: end;
    }

    label {
      display: block;
      color: var(--muted);
      font-size: 12px;
      margin: 0 0 5px 2px;
    }

    input, textarea {
      width: 100%;
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.72);
      color: var(--text);
      border-radius: var(--radius-md);
      outline: none;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.65);
    }

    input {
      height: 42px;
      padding: 0 12px;
      font-size: 15px;
    }

    input:focus, textarea:focus {
      border-color: rgba(157, 119, 95, 0.5);
      box-shadow: 0 0 0 4px rgba(157, 119, 95, 0.11);
    }

    .mini-btn {
      height: 42px;
      padding: 0 13px;
      border-radius: 999px;
      color: var(--accent-dark);
      background: var(--accent-soft);
      font-weight: 650;
      white-space: nowrap;
    }

    main {
      flex: 1;
      padding: 12px 0 var(--footer-hint);
    }

    .chat {
      display: flex;
      flex-direction: column;
      gap: 13px;
    }

    .empty {
      margin-top: 20px;
      color: var(--muted);
      text-align: center;
      line-height: 1.8;
      border: 1px dashed var(--line);
      border-radius: var(--radius-xl);
      padding: 42px 20px;
      background: rgba(255, 255, 255, 0.44);
    }

    .msg {
      display: flex;
      flex-direction: column;
      gap: 5px;
      max-width: 82%;
      animation: rise 0.18s ease both;
    }

    @keyframes rise {
      from { opacity: 0; transform: translateY(5px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .msg.me {
      align-self: flex-end;
      align-items: flex-end;
    }

    .msg.other {
      align-self: flex-start;
      align-items: flex-start;
    }

    .role-name {
      color: var(--muted);
      font-size: 12px;
      padding: 0 8px;
    }

    .bubble {
      white-space: pre-wrap;
      word-break: break-word;
      line-height: 1.65;
      padding: 11px 14px;
      border-radius: 22px;
      background: rgba(255, 255, 255, 0.9);
      border: 1px solid rgba(142, 114, 91, 0.14);
      box-shadow: var(--shadow-soft);
    }

    .msg.me .bubble {
      background: linear-gradient(135deg, #9d775f, #81604d);
      color: #fff;
      border-color: rgba(255, 255, 255, 0.18);
    }

    .composer-wrap {
      position: fixed;
      left: 50%;
      bottom: 0;
      z-index: 20;
      width: min(920px, 100%);
      transform: translateX(-50%);
      padding: 18px 14px calc(12px + env(safe-area-inset-bottom));
      background: linear-gradient(180deg, rgba(251, 245, 238, 0), rgba(251, 245, 238, 0.96) 30%, rgba(251, 245, 238, 0.98));
      pointer-events: none;
    }

    .composer {
      pointer-events: auto;
      background: rgba(255, 253, 250, 0.9);
      border: 1px solid rgba(142, 114, 91, 0.18);
      border-radius: 30px;
      box-shadow: var(--shadow);
      backdrop-filter: blur(20px);
      padding: 12px;
    }

    .role-bar {
      min-height: 34px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      margin-bottom: 8px;
      color: var(--accent-dark);
    }

    .flow {
      display: flex;
      align-items: center;
      gap: 8px;
      min-width: 0;
      flex: 1;
    }

    .current-pill, .flow-pill, .role-chip {
      border-radius: 999px;
      border: 1px solid rgba(142, 114, 91, 0.17);
      background: rgba(242, 230, 220, 0.72);
      color: var(--accent-dark);
      font-size: 13px;
      font-weight: 700;
    }

    .current-pill {
      padding: 8px 11px;
      max-width: 34%;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .flow-pill {
      padding: 8px 11px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .auto-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 10px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.64);
      border: 1px solid rgba(142, 114, 91, 0.15);
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
      white-space: nowrap;
    }

    .role-scroll {
      display: flex;
      gap: 7px;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      flex: 1;
      padding-bottom: 1px;
    }

    .role-scroll::-webkit-scrollbar { display: none; }

    .role-chip {
      flex: 0 0 auto;
      padding: 8px 12px;
    }

    .role-chip.active {
      color: #fff;
      background: var(--accent);
      border-color: var(--accent);
    }

    .icon-btn {
      width: 38px;
      height: 38px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      background: rgba(242, 230, 220, 0.78);
      color: var(--accent-dark);
      border: 1px solid rgba(142, 114, 91, 0.12);
      flex: 0 0 auto;
    }

    .icon-btn.danger-soft {
      color: var(--danger);
      background: var(--danger-soft);
    }

    .icon-btn.primary {
      background: linear-gradient(135deg, #9d775f, #7d5d4a);
      color: #fff;
      box-shadow: 0 9px 18px rgba(125, 93, 74, 0.22);
    }

    .icon-btn svg, .text-btn svg {
      width: 20px;
      height: 20px;
      stroke: currentColor;
      fill: none;
      stroke-width: 1.85;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .message-input {
      min-height: 54px;
      max-height: 130px;
      resize: none;
      padding: 13px 14px;
      line-height: 1.5;
      border-radius: 21px;
      font-size: 16px;
      display: block;
    }

    .action-row {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: 9px;
    }

    .spacer { flex: 1; }

    .text-btn {
      height: 38px;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 0 14px;
      border-radius: 999px;
      color: var(--accent-dark);
      background: rgba(242, 230, 220, 0.78);
      font-weight: 750;
      border: 1px solid rgba(142, 114, 91, 0.12);
      white-space: nowrap;
    }

    .sheet-backdrop, .dialog-backdrop {
      position: fixed;
      inset: 0;
      z-index: 50;
      background: rgba(47, 41, 36, 0.22);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.18s ease;
    }

    .sheet-backdrop.show, .dialog-backdrop.show {
      opacity: 1;
      pointer-events: auto;
    }

    .sheet {
      position: fixed;
      left: 50%;
      bottom: 0;
      width: min(620px, 100%);
      transform: translateX(-50%) translateY(105%);
      z-index: 55;
      padding: 0 14px calc(14px + env(safe-area-inset-bottom));
      transition: transform 0.24s ease;
      pointer-events: none;
    }

    .sheet.show {
      transform: translateX(-50%) translateY(0);
      pointer-events: auto;
    }

    .sheet-card, .dialog {
      background: rgba(255, 253, 250, 0.96);
      border: 1px solid rgba(142, 114, 91, 0.18);
      border-radius: 30px;
      box-shadow: var(--shadow);
      backdrop-filter: blur(22px);
    }

    .sheet-card {
      max-height: min(78vh, 620px);
      overflow: auto;
      padding: 16px;
    }

    .sheet-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 14px;
    }

    .sheet-title {
      font-size: 18px;
      font-weight: 800;
    }

    .section-title {
      margin: 18px 0 8px;
      color: var(--muted);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.04em;
    }

    .role-manage-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .role-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      padding: 9px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.62);
      border: 1px solid rgba(142, 114, 91, 0.12);
    }

    .role-item-name {
      min-width: 0;
      flex: 1;
      font-weight: 750;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .tag {
      display: inline-flex;
      align-items: center;
      height: 24px;
      padding: 0 8px;
      border-radius: 999px;
      background: var(--accent-soft);
      color: var(--accent-dark);
      font-size: 11px;
      font-weight: 800;
      white-space: nowrap;
    }

    .role-tools {
      display: flex;
      gap: 6px;
      flex-wrap: nowrap;
    }

    .small-btn {
      height: 32px;
      padding: 0 10px;
      border-radius: 999px;
      background: var(--accent-soft);
      color: var(--accent-dark);
      font-size: 12px;
      font-weight: 800;
      white-space: nowrap;
    }

    .small-btn.danger {
      background: var(--danger-soft);
      color: var(--danger);
    }

    .add-row {
      display: flex;
      gap: 8px;
    }

    .dialog-wrap {
      position: fixed;
      inset: 0;
      z-index: 60;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 18px;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.18s ease;
    }

    .dialog-wrap.show {
      opacity: 1;
      pointer-events: auto;
    }

    .dialog {
      width: min(390px, 100%);
      padding: 18px;
      text-align: center;
    }

    .dialog h2 {
      margin: 2px 0 8px;
      font-size: 19px;
    }

    .dialog p {
      margin: 0;
      color: var(--muted);
      line-height: 1.6;
      font-size: 14px;
    }

    .dialog-actions {
      display: flex;
      gap: 9px;
      margin-top: 16px;
    }

    .dialog-actions button {
      flex: 1;
      height: 42px;
      border-radius: 999px;
      font-weight: 800;
    }

    .cancel-btn {
      background: var(--accent-soft);
      color: var(--accent-dark);
    }

    .confirm-danger {
      background: var(--danger);
      color: #fff;
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: calc(198px + env(safe-area-inset-bottom));
      z-index: 80;
      transform: translateX(-50%) translateY(8px);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s ease, transform 0.2s ease;
      background: rgba(47, 41, 36, 0.92);
      color: #fff;
      padding: 10px 14px;
      border-radius: 999px;
      font-size: 14px;
      white-space: nowrap;
      max-width: calc(100% - 32px);
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .toast.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }



    /* 对话札记顶部：只替换原顶部，不影响底部输入区 */
    .topbar {
      height: calc(62px + env(safe-area-inset-top));
      margin: calc(-14px - env(safe-area-inset-top)) -14px 0;
      padding: env(safe-area-inset-top) 14px 0;
      background: linear-gradient(180deg, rgba(251, 245, 238, 0.96), rgba(251, 245, 238, 0.78));
      border-bottom: 1px solid rgba(142, 114, 91, 0.08);
      backdrop-filter: blur(18px);
    }

    .topbar-inner {
      height: 62px;
      display: grid;
      grid-template-columns: 84px 1fr 84px;
      align-items: center;
      gap: 8px;
    }

    .brand-title {
      text-align: center;
      font-size: 18px;
      font-weight: 760;
      line-height: 1.2;
      letter-spacing: 0.02em;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .top-actions {
      display: flex;
      justify-content: flex-end;
      align-items: center;
      gap: 8px;
    }

    .top-icon-btn {
      width: 40px;
      height: 40px;
      border-radius: 999px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: rgba(255, 255, 255, 0.64);
      color: var(--accent-dark);
      border: 1px solid var(--line);
      box-shadow: 0 6px 18px rgba(91, 61, 38, 0.06);
      flex: 0 0 auto;
    }

    .top-icon-btn svg {
      width: 20px;
      height: 20px;
      stroke: currentColor;
      fill: none;
      stroke-width: 1.9;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .field { margin: 12px 0; }

    .field label {
      display: block;
      color: var(--muted);
      font-size: 13px;
      margin: 0 0 7px 2px;
    }

    .field input {
      width: 100%;
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.72);
      color: var(--text);
      border-radius: 18px;
      padding: 0 13px;
      outline: none;
      font-size: 16px;
      height: 44px;
    }

    .sheet-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      justify-content: flex-end;
      margin-top: 16px;
    }

    .action-btn {
      min-height: 42px;
      border-radius: 999px;
      padding: 0 16px;
      background: var(--accent);
      color: #fff;
      font-weight: 780;
    }

    .action-btn.secondary {
      background: var(--accent-soft);
      color: var(--accent-dark);
    }

    .about-text {
      color: var(--text);
      line-height: 1.8;
      white-space: pre-wrap;
      font-size: 15px;
    }

    @media (max-width: 640px) {
      :root { --footer-hint: 204px; }

      .app {
        padding-left: 10px;
        padding-right: 10px;
      }

      .topbar { margin-left: -10px; margin-right: -10px; padding-left: 10px; padding-right: 10px; }

      .topbar-inner { grid-template-columns: 68px 1fr 76px; }

      .top-fields {
        grid-template-columns: 1fr;
      }

      .brand-row {
        margin-bottom: 8px;
      }

      .hint {
        display: none;
      }

      .top-card {
        padding: 11px;
        border-radius: 24px;
      }

      h1 { font-size: 17px; }

      .msg { max-width: 90%; }

      .composer-wrap {
        padding-left: 10px;
        padding-right: 10px;
      }

      .composer {
        border-radius: 27px;
        padding: 10px;
      }

      .current-pill {
        max-width: 42%;
      }

      .flow-pill {
        max-width: 34%;
      }

      .auto-pill .auto-label {
        display: none;
      }

      .text-btn {
        padding: 0 12px;
      }

      .icon-btn {
        width: 37px;
        height: 37px;
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <header class="topbar">
      <div class="topbar-inner">
        <div></div>
        <div class="brand-title" id="displayTitle">聊天</div>
        <div class="top-actions">
          <button class="top-icon-btn" id="aboutBtn" type="button" aria-label="关于">
            <svg viewBox="0 0 24 24"><path d="M9.2 9a3 3 0 1 1 4.8 2.4c-1.2.8-1.9 1.4-1.9 2.7v.3"/><path d="M12 18h.01"/><circle cx="12" cy="12" r="9"/></svg>
          </button>
          <button class="top-icon-btn" id="editTitleBtn" type="button" aria-label="编辑标题">
            <svg viewBox="0 0 24 24"><path d="M13.5 6.5l4 4"/><path d="M4 20l4.6-1 9.8-9.8a2.4 2.4 0 0 0-3.4-3.4L5.2 15.6 4 20z"/><path d="M14.8 5.2l4 4"/></svg>
          </button>
        </div>
      </div>
    </header>

    <main>
      <section class="chat" id="chatList"></section>
    </main>
  </div>

  <footer class="composer-wrap">
    <section class="composer">
      <div class="role-bar" id="roleBar"></div>
      <textarea class="message-input" id="messageInput" placeholder="说点什么……"></textarea>
      <div class="action-row">
        <button class="icon-btn" id="undoBtn" type="button" aria-label="撤回上一条" title="撤回上一条"></button>
        <button class="icon-btn" id="roleManageBtn" type="button" aria-label="角色管理" title="角色管理"></button>
        <button class="icon-btn danger-soft" id="clearBtn" type="button" aria-label="清空聊天" title="清空聊天"></button>
        <span class="spacer"></span>
        <button class="text-btn" id="exportMenuBtn" type="button" aria-label="导出">导出</button>
        <button class="icon-btn primary" id="sendBtn" type="button" aria-label="发送" title="发送"></button>
      </div>
    </section>
  </footer>

  <div class="sheet-backdrop" id="sheetBackdrop"></div>



  <section class="sheet" id="titleSheet" aria-hidden="true">
    <div class="sheet-card">
      <div class="sheet-head">
        <div class="sheet-title">聊天设置</div>
        <button class="icon-btn" id="closeTitleSheetBtn" type="button" aria-label="关闭"></button>
      </div>
      <div class="field">
        <label for="chatTitleInput">标题</label>
        <input id="chatTitleInput" placeholder="聊天" />
      </div>
      <div class="sheet-actions">
        <button class="action-btn" id="saveTitleBtn" type="button">完成</button>
      </div>
    </div>
  </section>

  <section class="sheet" id="aboutSheet" aria-hidden="true">
    <div class="sheet-card">
      <div class="sheet-head">
        <div class="sheet-title">关于对话札记</div>
        <button class="icon-btn" id="closeAboutSheetBtn" type="button" aria-label="关闭"></button>
      </div>
      <div class="about-text">这是一个本地聊天记录保存工具。
内容只保存在当前浏览器本地，不会上传。
你可以切换角色、自动轮流发言，并导出 Markdown 文件。

请勿用于保存或传播违法、侵权或未经授权的内容。</div>
    </div>
  </section>

  <section class="sheet" id="roleSheet" aria-hidden="true">
    <div class="sheet-card">
      <div class="sheet-head">
        <div class="sheet-title">角色管理</div>
        <button class="icon-btn" id="closeRoleSheetBtn" type="button" aria-label="关闭"></button>
      </div>

      <div class="section-title">添加角色</div>
      <div class="add-row">
        <input id="newRoleInput" placeholder="比如：朋友、老师、旁白" />
        <button class="mini-btn" id="addRoleBtn" type="button">添加</button>
      </div>

      <div class="section-title">角色列表</div>
      <div class="role-manage-list" id="roleManageList"></div>
    </div>
  </section>

  <section class="sheet" id="exportSheet" aria-hidden="true">
    <div class="sheet-card">
      <div class="sheet-head">
        <div class="sheet-title">导出</div>
        <button class="icon-btn" id="closeExportSheetBtn" type="button" aria-label="关闭"></button>
      </div>
      <div class="field">
        <label for="exportDateInput">日期</label>
        <input id="exportDateInput" type="date" />
      </div>
      <div class="field">
        <label for="filenameInput">文件名</label>
        <input id="filenameInput" placeholder="20260426聊天.md" />
      </div>
      <div class="sheet-actions">
        <button class="action-btn secondary" id="copyBtn" type="button">复制 Markdown</button>
        <button class="action-btn" id="downloadBtn" type="button">下载 .md</button>
      </div>
    </div>
  </section>

  <div class="dialog-backdrop" id="dialogBackdrop"></div>
  <div class="dialog-wrap" id="clearDialog" aria-hidden="true">
    <section class="dialog">
      <h2>清空聊天记录？</h2>
      <p>这个操作不能恢复。只会清空聊天内容，不会删除标题、时间和角色设置。</p>
      <div class="dialog-actions">
        <button class="cancel-btn" id="cancelClearBtn" type="button">取消</button>
        <button class="confirm-danger" id="confirmClearBtn" type="button">确认清空</button>
      </div>
    </section>
  </div>

  <div class="toast" id="toast"></div>

  <script>
    const STORAGE_KEY = "chat_md_saver_v2";
    const OLD_STORAGE_KEY = "chat_md_saver_v1";

    const icons = {
      undo: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 8H4V3"/><path d="M4.8 8.1A8 8 0 1 1 7 19.2"/></svg>`,
      users: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M16 19c0-2.2-1.8-4-4-4H8c-2.2 0-4 1.8-4 4"/><circle cx="10" cy="8" r="3"/><path d="M20 19c0-1.8-1.1-3.3-2.7-3.8"/><path d="M16.5 5.3a3 3 0 0 1 0 5.4"/></svg>`,
      trash: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h16"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M6 7l1 13h10l1-13"/><path d="M9 7V4h6v3"/></svg>`,
      send: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 3 10 14"/><path d="M21 3 14 21l-4-7-7-4 18-7Z"/></svg>`,
      swap: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 7h12"/><path d="m16 4 3 3-3 3"/><path d="M17 17H5"/><path d="m8 14-3 3 3 3"/></svg>`,
      close: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 6l12 12"/><path d="M18 6 6 18"/></svg>`,
      download: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3v11"/><path d="m8 10 4 4 4-4"/><path d="M5 20h14"/></svg>`
    };

    const defaultState = {
      title: "聊天",
      chatTime: "",
      currentRole: "我",
      rightSideRole: "我",
      roles: ["我", "对方"],
      autoSwitchEnabled: true,
      messages: [],
      exportDate: ""
    };

    let state = loadState();
    let toastTimer = null;

    const displayTitle = document.getElementById("displayTitle");
    const editTitleBtn = document.getElementById("editTitleBtn");
    const aboutBtn = document.getElementById("aboutBtn");
    const chatTitleInput = document.getElementById("chatTitleInput");
    const saveTitleBtn = document.getElementById("saveTitleBtn");
    const closeTitleSheetBtn = document.getElementById("closeTitleSheetBtn");
    const closeAboutSheetBtn = document.getElementById("closeAboutSheetBtn");
    const exportDateInput = document.getElementById("exportDateInput");
    const filenameInput = document.getElementById("filenameInput");
    const chatList = document.getElementById("chatList");
    const roleBar = document.getElementById("roleBar");
    const messageInput = document.getElementById("messageInput");
    const undoBtn = document.getElementById("undoBtn");
    const roleManageBtn = document.getElementById("roleManageBtn");
    const clearBtn = document.getElementById("clearBtn");
    const exportMenuBtn = document.getElementById("exportMenuBtn");
    const sendBtn = document.getElementById("sendBtn");
    const sheetBackdrop = document.getElementById("sheetBackdrop");
    const titleSheet = document.getElementById("titleSheet");
    const aboutSheet = document.getElementById("aboutSheet");
    const roleSheet = document.getElementById("roleSheet");
    const exportSheet = document.getElementById("exportSheet");
    const closeRoleSheetBtn = document.getElementById("closeRoleSheetBtn");
    const closeExportSheetBtn = document.getElementById("closeExportSheetBtn");
    const newRoleInput = document.getElementById("newRoleInput");
    const addRoleBtn = document.getElementById("addRoleBtn");
    const roleManageList = document.getElementById("roleManageList");
    const copyBtn = document.getElementById("copyBtn");
    const downloadBtn = document.getElementById("downloadBtn");
    const dialogBackdrop = document.getElementById("dialogBackdrop");
    const clearDialog = document.getElementById("clearDialog");
    const cancelClearBtn = document.getElementById("cancelClearBtn");
    const confirmClearBtn = document.getElementById("confirmClearBtn");
    const toast = document.getElementById("toast");

    init();

    function init() {
      undoBtn.innerHTML = icons.undo;
      roleManageBtn.innerHTML = icons.users;
      clearBtn.innerHTML = icons.trash;
      sendBtn.innerHTML = icons.send;
      closeRoleSheetBtn.innerHTML = icons.close;
      closeExportSheetBtn.innerHTML = icons.close;
      closeTitleSheetBtn.innerHTML = icons.close;
      closeAboutSheetBtn.innerHTML = icons.close;

      normalizeState();
      if (!state.exportDate) state.exportDate = formatDateInput(new Date());

      bindEvents();
      renderAll();
      saveState();
    }

    function bindEvents() {
      editTitleBtn.addEventListener("click", openTitleSheet);
      aboutBtn.addEventListener("click", openAboutSheet);
      closeTitleSheetBtn.addEventListener("click", closeSheets);
      closeAboutSheetBtn.addEventListener("click", closeSheets);
      saveTitleBtn.addEventListener("click", saveTitleFromSheet);
      chatTitleInput.addEventListener("keydown", (event) => {
        if (event.key === "Enter") saveTitleFromSheet();
      });
      exportDateInput.addEventListener("input", updateFilenameDefault);
      filenameInput.addEventListener("focus", () => filenameInput.dataset.touched = "1");

      sendBtn.addEventListener("click", sendMessage);

      messageInput.addEventListener("input", () => {
        messageInput.style.height = "auto";
        messageInput.style.height = Math.min(messageInput.scrollHeight, 130) + "px";
      });

      messageInput.addEventListener("keydown", (event) => {
        if ((event.metaKey || event.ctrlKey) && event.key === "Enter") {
          event.preventDefault();
          sendMessage();
        }
      });

      undoBtn.addEventListener("click", undoLastMessage);
      roleManageBtn.addEventListener("click", openRoleSheet);
      clearBtn.addEventListener("click", openClearDialog);
      exportMenuBtn.addEventListener("click", openExportSheet);

      sheetBackdrop.addEventListener("click", closeSheets);
      closeRoleSheetBtn.addEventListener("click", closeSheets);
      closeExportSheetBtn.addEventListener("click", closeSheets);

      addRoleBtn.addEventListener("click", addRoleFromInput);
      newRoleInput.addEventListener("keydown", (event) => {
        if (event.key === "Enter") addRoleFromInput();
      });

      copyBtn.addEventListener("click", copyMarkdown);
      downloadBtn.addEventListener("click", exportMarkdown);

      dialogBackdrop.addEventListener("click", closeClearDialog);
      cancelClearBtn.addEventListener("click", closeClearDialog);
      confirmClearBtn.addEventListener("click", clearMessages);
    }

    function loadState() {
      try {
        const raw = localStorage.getItem(STORAGE_KEY) || localStorage.getItem(OLD_STORAGE_KEY) || localStorage.getItem("dialogue_note_v3") || localStorage.getItem("dialogue_note_v2");
        if (!raw) return structuredClone(defaultState);
        const parsed = JSON.parse(raw);
        return {
          ...structuredClone(defaultState),
          ...parsed,
          roles: Array.isArray(parsed.roles) && parsed.roles.length ? uniqueClean(parsed.roles) : structuredClone(defaultState.roles),
          messages: Array.isArray(parsed.messages) ? parsed.messages : []
        };
      } catch (error) {
        return structuredClone(defaultState);
      }
    }

    function normalizeState() {
      state.roles = uniqueClean(state.roles);
      if (!state.roles.length) state.roles = ["我"];

      if (!state.currentRole || !state.roles.includes(state.currentRole)) {
        state.currentRole = state.roles[0];
      }

      if (!state.rightSideRole || !state.roles.includes(state.rightSideRole)) {
        state.rightSideRole = state.roles.includes("我") ? "我" : state.roles[0];
      }

      if (typeof state.autoSwitchEnabled !== "boolean") {
        state.autoSwitchEnabled = true;
      }
    }

    function uniqueClean(list) {
      const result = [];
      list.forEach(item => {
        const role = String(item || "").trim();
        if (role && !result.includes(role)) result.push(role);
      });
      return result;
    }

    function saveState() {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
    }

    function renderAll() {
      normalizeState();
      renderHeader();
      renderRoleBar();
      renderMessages();
      renderRoleManageList();
    }

    function renderHeader() {
      const title = getDisplayTitle();
      displayTitle.textContent = title;
      document.title = title === "聊天" ? "对话札记" : title + "｜对话札记";
    }

    function renderRoleBar() {
      roleBar.innerHTML = "";

      if (state.roles.length === 1) {
        const flow = document.createElement("div");
        flow.className = "flow";
        flow.innerHTML = `<span class="current-pill">当前：${escapeHtml(state.currentRole)}</span>`;
        roleBar.appendChild(flow);
        return;
      }

      if (state.roles.length === 2) {
        const flow = document.createElement("div");
        flow.className = "flow";

        const current = document.createElement("button");
        current.type = "button";
        current.className = "current-pill";
        current.textContent = "当前：" + state.currentRole;
        current.addEventListener("click", () => {
          setRole(getOtherRole(state.currentRole));
        });

        const flowPill = document.createElement("span");
        flowPill.className = "flow-pill";
        flowPill.textContent = state.roles[0] + " → " + state.roles[1];

        const auto = document.createElement("button");
        auto.type = "button";
        auto.className = "auto-pill";
        auto.innerHTML = `<span class="auto-label">自动</span>${state.autoSwitchEnabled ? "开" : "关"}`;
        auto.addEventListener("click", () => {
          state.autoSwitchEnabled = !state.autoSwitchEnabled;
          saveState();
          renderRoleBar();
          showToast(state.autoSwitchEnabled ? "自动切换已开启" : "自动切换已关闭");
        });

        const swap = document.createElement("button");
        swap.type = "button";
        swap.className = "icon-btn";
        swap.title = "交换发言顺序";
        swap.setAttribute("aria-label", "交换发言顺序");
        swap.innerHTML = icons.swap;
        swap.addEventListener("click", swapRoleOrder);

        flow.appendChild(current);
        flow.appendChild(flowPill);
        flow.appendChild(auto);
        roleBar.appendChild(flow);
        roleBar.appendChild(swap);
        return;
      }

      const scroll = document.createElement("div");
      scroll.className = "role-scroll";
      state.roles.forEach(role => {
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "role-chip" + (role === state.currentRole ? " active" : "");
        btn.textContent = role;
        btn.addEventListener("click", () => setRole(role));
        scroll.appendChild(btn);
      });
      roleBar.appendChild(scroll);
    }

    function renderMessages() {
      chatList.innerHTML = "";

      if (!state.messages.length) {
        const empty = document.createElement("div");
        empty.className = "empty";
        empty.innerHTML = "还没有聊天记录。<br>选好角色，然后写下第一句话。";
        chatList.appendChild(empty);
        return;
      }

      state.messages.forEach(msg => {
        const roleText = String(msg.role || "未命名");
        const wrap = document.createElement("article");
        wrap.className = "msg " + (roleText === state.rightSideRole ? "me" : "other");

        const role = document.createElement("div");
        role.className = "role-name";
        role.textContent = roleText;

        const bubble = document.createElement("div");
        bubble.className = "bubble";
        bubble.textContent = String(msg.text || "");

        wrap.appendChild(role);
        wrap.appendChild(bubble);
        chatList.appendChild(wrap);
      });
    }

    function renderRoleManageList() {
      roleManageList.innerHTML = "";

      state.roles.forEach(role => {
        const row = document.createElement("div");
        row.className = "role-item";

        const name = document.createElement("div");
        name.className = "role-item-name";
        name.textContent = role;

        const tags = document.createElement("div");
        tags.style.display = "flex";
        tags.style.gap = "5px";
        tags.style.flexWrap = "wrap";
        if (role === state.currentRole) tags.appendChild(makeTag("当前"));
        if (role === state.rightSideRole) tags.appendChild(makeTag("右侧"));

        const tools = document.createElement("div");
        tools.className = "role-tools";

        const currentBtn = document.createElement("button");
        currentBtn.type = "button";
        currentBtn.className = "small-btn";
        currentBtn.textContent = "设当前";
        currentBtn.addEventListener("click", () => {
          setRole(role);
          renderRoleManageList();
        });

        const rightBtn = document.createElement("button");
        rightBtn.type = "button";
        rightBtn.className = "small-btn";
        rightBtn.textContent = "设右侧";
        rightBtn.addEventListener("click", () => {
          state.rightSideRole = role;
          saveState();
          renderAll();
          showToast("右侧角色：" + role);
        });

        const delBtn = document.createElement("button");
        delBtn.type = "button";
        delBtn.className = "small-btn danger";
        delBtn.textContent = "删除";
        delBtn.addEventListener("click", () => deleteRole(role));

        tools.appendChild(currentBtn);
        tools.appendChild(rightBtn);
        tools.appendChild(delBtn);

        const middle = document.createElement("div");
        middle.style.display = "flex";
        middle.style.flexDirection = "column";
        middle.style.gap = "5px";
        middle.style.minWidth = "0";
        middle.style.flex = "1";
        middle.appendChild(name);
        middle.appendChild(tags);

        row.appendChild(middle);
        row.appendChild(tools);
        roleManageList.appendChild(row);
      });
    }

    function makeTag(text) {
      const tag = document.createElement("span");
      tag.className = "tag";
      tag.textContent = text;
      return tag;
    }

    function setRole(role) {
      if (!state.roles.includes(role)) return;
      state.currentRole = role;
      saveState();
      renderRoleBar();
    }

    function getOtherRole(role) {
      if (state.roles.length !== 2) return role;
      return state.roles.find(item => item !== role) || role;
    }

    function swapRoleOrder() {
      if (state.roles.length !== 2) return;
      state.roles.reverse();
      state.currentRole = state.roles[0];
      saveState();
      renderAll();
      showToast("已交换发言顺序");
    }

    function addRoleFromInput() {
      const role = newRoleInput.value.trim();
      if (!role) {
        showToast("先输入角色名");
        return;
      }
      if (!state.roles.includes(role)) {
        state.roles.push(role);
      }
      state.currentRole = role;
      newRoleInput.value = "";
      saveState();
      renderAll();
      showToast("已添加/切换到：" + role);
    }

    function deleteRole(role) {
      if (state.roles.length <= 1) {
        showToast("至少需要保留一个角色");
        return;
      }

      state.roles = state.roles.filter(item => item !== role);
      if (!state.roles.length) state.roles = ["我"];

      if (state.currentRole === role || !state.roles.includes(state.currentRole)) {
        state.currentRole = state.roles[0];
      }
      if (state.rightSideRole === role || !state.roles.includes(state.rightSideRole)) {
        state.rightSideRole = state.roles[0];
      }

      saveState();
      renderAll();
      showToast("已删除角色：" + role);
    }

    function sendMessage() {
      const text = messageInput.value.trim();
      if (!text) {
        showToast("先输入消息");
        return;
      }

      state.messages.push({
        role: state.currentRole,
        text,
        createdAt: new Date().toISOString()
      });

      if (state.autoSwitchEnabled && state.roles.length === 2) {
        state.currentRole = getOtherRole(state.currentRole);
      }

      messageInput.value = "";
      messageInput.style.height = "auto";
      saveState();
      renderAll();
      requestAnimationFrame(scrollToBottom);
    }

    function undoLastMessage() {
      if (!state.messages.length) {
        showToast("没有可以撤回的消息");
        return;
      }

      const removed = state.messages.pop();
      if (removed && removed.role && state.roles.includes(removed.role)) {
        state.currentRole = removed.role;
      }

      saveState();
      renderAll();
      showToast("已撤回上一条");
    }

    function clearMessages() {
      state.messages = [];
      saveState();
      renderMessages();
      closeClearDialog();
      showToast("已清空聊天记录");
    }

    function openRoleSheet() {
      closeSheets(false);
      renderRoleManageList();
      sheetBackdrop.classList.add("show");
      roleSheet.classList.add("show");
      roleSheet.setAttribute("aria-hidden", "false");
      setTimeout(() => newRoleInput.focus(), 120);
    }

    function openTitleSheet() {
      closeSheets(false);
      chatTitleInput.value = state.title === "聊天" ? "" : (state.title || "");
      sheetBackdrop.classList.add("show");
      titleSheet.classList.add("show");
      titleSheet.setAttribute("aria-hidden", "false");
      setTimeout(() => chatTitleInput.focus(), 120);
    }

    function saveTitleFromSheet() {
      state.title = chatTitleInput.value.trim();
      saveState();
      renderHeader();
      closeSheets();
      showToast("已保存标题");
    }

    function openAboutSheet() {
      closeSheets(false);
      sheetBackdrop.classList.add("show");
      aboutSheet.classList.add("show");
      aboutSheet.setAttribute("aria-hidden", "false");
    }

    function openExportSheet() {
      closeSheets(false);
      exportDateInput.value = state.exportDate || formatDateInput(new Date());
      filenameInput.dataset.touched = "";
      filenameInput.value = buildDefaultFilename(exportDateInput.value);
      sheetBackdrop.classList.add("show");
      exportSheet.classList.add("show");
      exportSheet.setAttribute("aria-hidden", "false");
    }

    function closeSheets(hideBackdrop = true) {
      roleSheet.classList.remove("show");
      exportSheet.classList.remove("show");
      titleSheet.classList.remove("show");
      aboutSheet.classList.remove("show");
      roleSheet.setAttribute("aria-hidden", "true");
      exportSheet.setAttribute("aria-hidden", "true");
      titleSheet.setAttribute("aria-hidden", "true");
      aboutSheet.setAttribute("aria-hidden", "true");
      if (hideBackdrop) sheetBackdrop.classList.remove("show");
    }

    function openClearDialog() {
      dialogBackdrop.classList.add("show");
      clearDialog.classList.add("show");
      clearDialog.setAttribute("aria-hidden", "false");
    }

    function closeClearDialog() {
      dialogBackdrop.classList.remove("show");
      clearDialog.classList.remove("show");
      clearDialog.setAttribute("aria-hidden", "true");
    }

    function buildMarkdown() {
      const title = getDisplayTitle();
      const dateText = exportDateInput.value || state.exportDate || formatDateInput(new Date());

      let md = "";
      md += "# " + title + "\n\n";
      md += "时间：" + dateText + "\n\n";
      md += "---\n\n";
      md += "## 聊天记录\n\n";

      if (!state.messages.length) {
        md += "暂无聊天记录。\n";
        return md;
      }

      state.messages.forEach(msg => {
        md += "**" + escapeMarkdownBold(msg.role || "未命名") + "：**\n\n";
        md += String(msg.text || "").trim() + "\n\n";
      });

      return md.trim() + "\n";
    }

    async function copyMarkdown() {
      updateFilenameDefault();
      const md = buildMarkdown();
      try {
        await navigator.clipboard.writeText(md);
      } catch (error) {
        const temp = document.createElement("textarea");
        temp.value = md;
        document.body.appendChild(temp);
        temp.select();
        document.execCommand("copy");
        document.body.removeChild(temp);
      }
      closeSheets();
      showToast("已复制 Markdown");
    }

    function exportMarkdown() {
      updateFilenameDefault();
      const md = buildMarkdown();
      const filename = normalizeFilename(filenameInput.value || buildDefaultFilename(exportDateInput.value));
      const blob = new Blob([md], { type: "text/markdown;charset=utf-8" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = filename;
      document.body.appendChild(a);
      a.click();
      setTimeout(() => {
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
      }, 0);
      closeSheets();
      showToast("已导出：" + filename);
    }

    function updateFilenameDefault() {
      state.exportDate = exportDateInput.value || formatDateInput(new Date());
      saveState();
      if (!filenameInput.dataset.touched) filenameInput.value = buildDefaultFilename(state.exportDate);
    }

    function buildDefaultFilename(dateInput) {
      const datePart = dateInput ? dateInput.replace(/-/g, "") : formatDateForFilename(new Date());
      return datePart + sanitizeFilename(getDisplayTitle()) + ".md";
    }

    function normalizeFilename(value) {
      let name = sanitizeFilename(String(value || "").trim());
      if (!name) name = buildDefaultFilename(exportDateInput.value);
      if (!/\.md$/i.test(name)) name += ".md";
      return name;
    }

    function getDisplayTitle() {
      return (state.title || "").trim() || "聊天";
    }

    function sanitizeFilename(name) {
      return name
        .replace(/[\\/:*?"<>|#%&{}$!'@+=`]/g, "")
        .replace(/\s+/g, "")
        .slice(0, 60);
    }

    function escapeMarkdownBold(text) {
      return String(text).replace(/\*/g, "\\*");
    }

    function escapeHtml(text) {
      return String(text)
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

    function formatDateInput(date) {
      const y = date.getFullYear();
      const m = String(date.getMonth() + 1).padStart(2, "0");
      const d = String(date.getDate()).padStart(2, "0");
      return `${y}-${m}-${d}`;
    }

    function formatDisplayDateTime(date) {
      const y = date.getFullYear();
      const m = String(date.getMonth() + 1).padStart(2, "0");
      const d = String(date.getDate()).padStart(2, "0");
      const hh = String(date.getHours()).padStart(2, "0");
      const mm = String(date.getMinutes()).padStart(2, "0");
      return `${y}-${m}-${d} ${hh}:${mm}`;
    }

    function formatDateForFilename(date) {
      const y = date.getFullYear();
      const m = String(date.getMonth() + 1).padStart(2, "0");
      const d = String(date.getDate()).padStart(2, "0");
      return `${y}${m}${d}`;
    }

    function scrollToBottom() {
      window.scrollTo({ top: document.body.scrollHeight, behavior: "smooth" });
    }

    function showToast(message) {
      toast.textContent = message;
      toast.classList.add("show");
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => toast.classList.remove("show"), 1700);
    }
  </script>
</body>
</html>
